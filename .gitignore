node_modules/
frontend/dist/
frontend/build/
.eslintcache
*.tsbuildinfo

# ── Docker ──
docker-compose.override.yml

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──
*.log
logs/

