# ═══════════════════════════════════════════
# Evently — Environment Configuration
# ═══════════════════════════════════════════
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ── App ──
FLASK_ENV=production
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
APP_DOMAIN=evently.yourdomain.com
FRONTEND_URL=https://evently.yourdomain.com

# ── Database ──
POSTGRES_USER=evently
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=evently
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://evently:CHANGE_ME_STRONG_PASSWORD@postgres:5432/evently

# ── Redis ──
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX

# ── SendGrid ──
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXX
FROM_EMAIL=noreply@yourdomain.com

# ── Google APIs ──
GOOGLE_CLIENT_ID=XXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXX
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXX

# ── DocuSign ──
DOCUSIGN_INTEGRATION_KEY=XXXXXXXX
DOCUSIGN_SECRET_KEY=XXXXXXXX
DOCUSIGN_ACCOUNT_ID=XXXXXXXX

# ── QuickBooks ──
QB_CLIENT_ID=XXXXXXXX
QB_CLIENT_SECRET=XXXXXXXX
QB_REDIRECT_URI=https://evently.yourdomain.com/api/v1/integrations/quickbooks/callback

# ── Linode Object Storage (S3-Compatible) ──
S3_ENDPOINT=https://us-east-1.linodeobjects.com
S3_ACCESS_KEY=XXXXXXXX
S3_SECRET_KEY=XXXXXXXX
S3_BUCKET=evently-uploads
S3_REGION=us-east-1

# ── Deployment ──
LINODE_IP=YOUR_LINODE_IP_ADDRESS
DEPLOY_USER=deploy
SSH_KEY_PATH=~/.ssh/evently_deploy

# ── Monitoring ──
SENTRY_DSN=https://XXXXXXXX@sentry.io/XXXXXXXX
LOG_LEVEL=INFO
